&pinctrl {
    spis1_default: spis1_default {
        group1 {
            psels = <NRF_PSEL(SPIS_SCK,  0, 29)>,
                    <NRF_PSEL(SPIS_MISO, 0, 02)>,
                    <NRF_PSEL(SPIS_MOSI, 1, 15)>,
                    <NRF_PSEL(SPIS_CSN,  1, 13)>;
        };
    };
    spis1_sleep: spis1_sleep {
        group1 {
            psels = <NRF_PSEL(SPIS_SCK,  0, 29)>,
                    <NRF_PSEL(SPIS_MISO, 0, 02)>,
                    <NRF_PSEL(SPIS_MOSI, 1, 15)>,
                    <NRF_PSEL(SPIS_CSN,  1, 13)>;
            low-power-enable;
        };
    };
};

/*
 * compatible = "nordic,nrf-spis" triggers DT_HAS_NORDIC_NRF_SPIS_ENABLED
 * which auto-selects NRFX_SPIS via SPI_NRFX_SPIS - no manual Kconfig needed
 * CSN pin is defined here in pinctrl, NOT via cs-gpios for SPIS
 */
&spi1 {
    compatible = "nordic,nrf-spis";
    status = "okay";
    def-char = <0xFF>;
    pinctrl-0 = <&spis1_default>;
    pinctrl-1 = <&spis1_sleep>;
    pinctrl-names = "default", "sleep";
};